# Environment Configuration Example

# ===== LOCAL DEVELOPMENT =====
# Копируй в .env.local
VITE_ENV=local
VITE_APP_NAME=my-project
VITE_GRPC_HOST=http://localhost:44044
VITE_ENABLE_MOCK_DATA=true
VITE_ENABLE_DEBUG_LOGS=true
VITE_ENABLE_DEVTOOLS=true

# ===== STAGE =====
# Копируй в .env.stage
# VITE_ENV=stage
# VITE_GRPC_HOST=https://YOUR_STAGE_GATEWAY.apigw.yandexcloud.net
# VITE_ENABLE_MOCK_DATA=true
# VITE_ENABLE_DEBUG_LOGS=true
# VITE_ENABLE_DEVTOOLS=false

# ===== PRODUCTION =====
# Копируй в .env.production
# VITE_ENV=production
# VITE_GRPC_HOST=https://YOUR_PROD_GATEWAY.apigw.yandexcloud.net
# VITE_ENABLE_MOCK_DATA=false
# VITE_ENABLE_DEBUG_LOGS=false
# VITE_ENABLE_DEVTOOLS=false

# ===== ИНСТРУКЦИЯ =====
# 1. Local: yarn dev (использует .env.local)
# 2. Stage: yarn build --mode stage (использует .env.stage)
# 3. Production: yarn build --mode production (использует .env.production)
#
# 4. Вставь URL контейнеров из Yandex Cloud:
#    - Stage: my-project-api-stage
#    - Production: my-project-api
