# ===========================================
# Server Configuration
# ===========================================
# Локальная разработка: 44044
# YC Serverless Containers: 8080 (через HTTP_PORT env)
SERVER_PORT=44044
SERVER_HOST=0.0.0.0

# ===========================================
# Database Configuration
# ===========================================
# PostgreSQL connection string
DATABASE_URL=postgres://postgres:postgres@localhost:5432/app?sslmode=disable

# ===========================================
# JWT Configuration
# ===========================================
# IMPORTANT: Change this in production!
JWT_SECRET=change-me-in-production-use-32-chars-min

# Token durations (Go duration format: 15m, 1h, 24h, 7d)
ACCESS_TOKEN_DURATION=15m
REFRESH_TOKEN_DURATION=168h  # 7 days

# ===========================================
# Security Configuration
# ===========================================
# Bcrypt cost (12 is recommended for production)
BCRYPT_COST=12

# Account lockout settings
MAX_FAILED_ATTEMPTS=5
ACCOUNT_LOCK_DURATION=30m

# Rate limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=1m

# ===========================================
# CORS Configuration
# ===========================================
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000

# ===========================================
# Environment
# ===========================================
# Options: development, staging, production
ENVIRONMENT=development
